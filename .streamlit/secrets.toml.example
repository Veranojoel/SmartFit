# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is git-ignored and must never be committed.

# Required: Google Gemini API key
GEMINI_API_KEY = "your_gemini_api_key_here"

# Optional: set a password to restrict access to the app.
# When set, all users must enter this password before the app loads.
# Leave blank (or remove this line) to disable the password gate.
# APP_PASSWORD = "your_password_here"
